# Environment Configuration Template
# Duplicate this file to .env and adjust variables as required for your environment.

# Node environment mode (development, production, test)
NODE_ENV=development

# Logging verbosity level (debug, info, warn, error)
LOG_LEVEL=info

# Port on which the HTTP API application listens
PORT=3000

# JSON-RPC Provider node endpoint URL for block reading
RPC_URL=http://localhost:8545

# Database connection credentials URI string (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgrespassword@localhost:5432/sera_data

# Redis connection URI string for task queuing
REDIS_URL=redis://localhost:6379

# Blockchain height from which the indexer starts synchronization
START_BLOCK=20000000

# Number of blocks required to consider a block finalized
RECONFIRMATION_DEPTH=6
