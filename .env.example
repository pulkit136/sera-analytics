# ==============================================================================
# sera-data Environment Configuration Template
# Copy this file to .env and configure the variables for local run.
# ==============================================================================

# Node Environment
NODE_ENV=development
LOG_LEVEL=info

# JSON-RPC Provider Endpoints (Mainnet)
RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your-api-key
# Secondary backup endpoint
RPC_URL_FALLBACK=https://mainnet.infura.io/v3/your-api-key

# PostgreSQL Connection String (Database Layer)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sera_data?schema=public

# Redis Connection Details (For indexer lock & local caches if needed)
REDIS_URL=redis://localhost:6379

# Indexing Start Block (Sera V2 deployments start around block 20000000)
START_BLOCK=20000000

# Reconfirmation Block Depth (Reorg protection)
RECONFIRMATION_DEPTH=6
